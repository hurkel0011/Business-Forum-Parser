# ===========================================
# Business Forum Parser - Environment Config
# ===========================================
# Copy this file to .env and fill in your keys.
# Get your keys from:
#   Anthropic  → https://console.anthropic.com/settings/keys
#   Reddit     → https://www.reddit.com/prefs/apps (create "script" type app)
#   GitHub     → https://github.com/settings/tokens (optional, increases rate limits)

# --- Required ---
ANTHROPIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Optional ---
GITHUB_TOKEN=
REDDIT_USER_AGENT=ForumParser/1.0
MIN_LEAD_SCORE=5.0
MAX_RESULTS_PER_SOURCE=50
